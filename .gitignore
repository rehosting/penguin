fw
# Generated during the container build; absent in source checkouts (penguin
# __init__ falls back to a dev version, so the unit tests don't need it).
src/penguin/version.txt
# Editable-install / build metadata (pip install -e src -e pengutils).
*.egg-info/
src/build/
pengutils/build/
db/events.*
local_packages/*
# keep the dir present so `COPY ./local_package[s]` works under podman/buildah
!local_packages/.gitkeep
# Downloaded ISF cache for the host test suite (penguin.testing.resolve_igloo_ko_isf)
tests/unit/.isf_cache/
src/penguin/testing/.isf_cache/
# coverage.py data
.coverage

# Per-worktree workspace template + stray logs (never belong in the repo)
CLAUDE.md
*.log

# Nix build symlinks (./penguin --build, nix build .#dockerImage, etc.)
/result
/result-*

# basic_target test-run artifacts
tests/unit_tests/basic_target/fs/
tests/unit_tests/basic_target/test_log.txt
